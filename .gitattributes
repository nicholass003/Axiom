# Normalize all text files to LF
* text=auto eol=lf

# Source code
*.php text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# GitHub / config
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Windows scripts (if ever added)
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (do not modify)
*.phar binary
*.nbt binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.jar binary